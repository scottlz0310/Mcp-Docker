# Force LF for all text files by default
* text=auto eol=lf

# Shell scripts must always use LF
*.sh        text eol=lf
*.bats      text eol=lf

# Windows-specific scripts keep CRLF
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary files
*.png       binary
*.jpg       binary
*.gif       binary
